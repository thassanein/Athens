{
  "name": "evro-server",
  "version": "0.1.0",
  "description": "Express + PostgreSQL API for Athens EVRO (cost-management PoC). Serves the SPA and /api from one origin.",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "migrate": "node db/migrate.js",
    "seed": "node db/migrate.js",
    "sql": "node db/make-sql.mjs"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "pg": "^8.12.0"
  },
  "engines": { "node": ">=18" }
}
