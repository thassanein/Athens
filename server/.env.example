# PostgreSQL connection — discrete variables
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=
PGDATABASE=athens_compliance

# HTTP server port
PORT=4000

# Alternatively, instead of the discrete PG* variables above, you can set a
# single connection string and it will take precedence:
# DATABASE_URL=postgresql://postgres:@localhost:5432/athens_compliance
