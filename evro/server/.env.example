# EVRO server config. Copy to .env for local dev (dotenv loads it).
# Either set a single connection string…
# DATABASE_URL=postgres://user:pass@localhost:5432/evro
# …or the discrete PG* vars (pg reads these automatically):
PGHOST=/tmp
PGPORT=5601
PGUSER=postgres
PGDATABASE=evro
PORT=4100
# NODE_ENV=production   # serve the built SPA from ../frontend/dist
# AUTO_RESEED=false     # only seed an empty DB (don't re-seed on data change)
# CORS_ORIGIN=https://example.com   # extra allowed origin (open mode already sends * on /api)
