# --- Database ---
# PostgreSQL connection string. For Neon, copy it from the Neon dashboard.
DATABASE_URL=postgresql://user:password@host:5432/databasename

# SSL handling for the database connection.
#   - Leave PGSSL unset for managed/cloud databases (Neon, RDS, etc.) — SSL is used automatically.
#   - Set PGSSL=disable only for a plain internal server that does NOT use SSL.
# PGSSL=disable

# --- App ---
# Long random string used to sign session cookies.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=replace-me-with-a-long-random-string

# First admin account, created by `npm run seed`.
SEED_ADMIN_EMAIL=admin@athensservices.com
SEED_ADMIN_PASSWORD=change-me-after-first-login

# Set to production when deploying.
NODE_ENV=production

# Optional: port for `npm start` (defaults to 3000). Hosts like Vercel set this for you.
# PORT=3000
