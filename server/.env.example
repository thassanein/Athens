# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
# Discrete variables (local dev):
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=
PGDATABASE=athens_compliance
# ...or a single connection string (takes precedence; this is what Render gives):
# DATABASE_URL=postgresql://user:pass@host:5432/athens_compliance

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------
PORT=4000
# NODE_ENV=production           # in prod: serves the built frontend + secure cookies

# ---------------------------------------------------------------------------
# Auth — pick ONE. Leave all blank for local "open" dev mode.
# ---------------------------------------------------------------------------

# Option A — shared team passcodes (no Microsoft admin needed). Entering a
# passcode signs you in with that role. Use long, random values.
# AUDITOR_PASSCODE=change-me-auditor
# VIEWER_PASSCODE=change-me-viewer

# Option B — Microsoft Entra (Azure AD) SSO. When all four ENTRA_* values are
# set, Microsoft sign-in is required (and takes precedence over passcodes).
# ENTRA_CLIENT_ID=00000000-0000-0000-0000-000000000000      # App (client) ID
# ENTRA_TENANT_ID=00000000-0000-0000-0000-000000000000      # Directory (tenant) ID
# ENTRA_CLIENT_SECRET=your-client-secret-value
# ENTRA_REDIRECT_URI=https://your-app.onrender.com/auth/redirect
# SESSION_SECRET=generate-a-long-random-string

# Role mapping. App roles in the token win; otherwise this allowlist; otherwise DEFAULT_ROLE.
# AUDITOR_EMAILS=dave@athens.example,rosa@athens.example
# DEFAULT_ROLE=viewer

# Optional: only if the frontend is hosted on a DIFFERENT origin than the API.
# CORS_ORIGIN=https://thassanein.github.io
